# ── Redis (kept for distributed locking only) ─────────────────────────────────
# Use redis:// (plain TCP) — not rediss:// — for Redis Cloud on non-standard ports
REDIS_URL=redis://default:<password>@<host>:<port>

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key — NEVER expose this to clients or commit to git
SUPABASE_SECRET_KEY=sb_secret_...
# Personal access token for running migrations — supabase.com → Account → Access Tokens
SUPABASE_MANAGEMENT_TOKEN=sbp_...

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
# Default model — change to any Groq-hosted model
GROQ_MODEL=llama-3.3-70b-versatile

# ── Optional tuning ───────────────────────────────────────────────────────────
MAX_CONVERSATIONS_CONTEXT=20
